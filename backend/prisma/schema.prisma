generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecommendationStatus {
  PENDING
  COMPLETED
  NEEDS_FOLLOWUP
  FAILED
}

enum FeedbackResult {
  ACCEPTED
  REJECTED
  RETRY_REQUESTED
}

model User {
  id               String                  @id @default(cuid())
  email            String                  @unique
  passwordHash     String?
  name             String
  personalityStyle String?
  interests        String[]                @default([])
  goals            String[]                @default([])
  constraints      String[]                @default([])
  budgetAmount     Int?
  budgetCurrency   String                  @default("INR")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  preferences      UserPreference[]
  sessions         RecommendationSession[]
  feedbackEntries  Feedback[]
  embeddings       MemoryEmbedding[]
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  category  String
  label     String
  weight    Float    @default(0.5)
  polarity  String   @default("positive")
  evidence  String[] @default([])
  source    String   @default("profile")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
}

model RecommendationSession {
  id                  String               @id @default(cuid())
  userId              String
  prompt              String
  normalizedPrompt    String
  domain              String
  status              RecommendationStatus @default(COMPLETED)
  planningNotes       String?
  summary             String?
  finalRecommendation String?
  confidenceScore     Int                  @default(0)
  riskLevel           String?
  whySelected         String[]             @default([])
  followUpQuestions   String[]             @default([])
  alternativeTitles   String[]             @default([])
  memoryInsights      String[]             @default([])
  retentionSummary    String?
  saved               Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  options             RecommendationOption[]
  agentMessages       AgentMessage[]
  feedbackEntries     Feedback[]
  embeddings          MemoryEmbedding[]

  @@index([userId, createdAt])
}

model RecommendationOption {
  id          String   @id @default(cuid())
  sessionId   String
  title       String
  description String
  score       Float
  rank        Int
  selected    Boolean  @default(false)
  pros        String[] @default([])
  cons        String[] @default([])
  risks       String[] @default([])
  tags        String[] @default([])
  evidence    String[] @default([])
  reasoning   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  session     RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, rank])
}

model AgentMessage {
  id        String    @id @default(cuid())
  sessionId String
  agent     String
  stage     String
  summary   String
  content   Json
  confidence Int?
  modelUsed String?
  createdAt DateTime  @default(now())
  session   RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model Feedback {
  id              String         @id @default(cuid())
  sessionId       String
  userId          String
  result          FeedbackResult
  reason          String?
  rating          Int?
  outcomeNotes    String?
  learningSummary String?
  preferenceDeltas Json?
  createdAt       DateTime       @default(now())
  session         RecommendationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model MemoryEmbedding {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String?
  vectorId   String   @unique
  collection String
  sourceType String
  content    String
  embedding  Float[]  @default([])
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    RecommendationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

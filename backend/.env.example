# === Runtime ===
NODE_ENV=development
PORT=8000
CORS_ORIGIN=http://localhost:3000

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/synod?schema=public

# === Auth ===
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# === AI ===
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === Embeddings ===
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Vector Memory ===
CHROMA_URL=
CHROMA_COLLECTION=synod-memory

# === Optional Web Search ===
SERPER_API_KEY=

# === Demo / Guest Mode ===
ENABLE_GUEST_MODE=true
DEMO_USER_EMAIL=demo@synod.local
DEMO_USER_PASSWORD=SynodDemo123!
